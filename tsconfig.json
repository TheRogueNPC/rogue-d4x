{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": [
    "src/**/*.ts",
    "src-tauri/**/*.ts",
    "src/frontend/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts",
    "vite.config.browser.ts",
    "vite.config.tauri.ts"
  ],
  "exclude": ["dist", "dist-browser", "node_modules", "Graphics Research- and foundation code"]
}
